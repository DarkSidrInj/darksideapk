    void *egl = dlopen_ex("libEGL.so", 4);
    pthread_t t;
    
    // Function to initialize the hooks
    void init_hooks() {
        while (!input) {input = dlopen_ex(OBFUSCATE("libinput.so"), 4); sleep(1);}
        void *address = dlsym_ex(input, OBFUSCATE("_ZN7android13InputConsumer21initializeMotionEventEPNS_11MotionEventEPKNS_12InputMessageE"));
        DobbyHook((void*)address, (void *)onInputEvent, (void **) &orig_onInputEvent);
        dlclose_ex(input);
        
        while (!egl) {
            egl = dlopen_ex("libEGL.so", 4);
            sleep(1);
        }
        DobbyHook((void *) dlsym_ex(egl, "eglSwapBuffers"), (void *) _SalvadorRENDER, (void **) &orig_SalvadorRENDER);
        
        items_data = json::parse(JSON_ITEMS);
        pthread_create(&t, nullptr, maps_thread, nullptr);
