// Custom toggle switch widget
bool ToggleSwitch(const char* label, bool* v) {
    ImGuiWindow* window = ImGui::GetCurrentWindow();
    if (window->SkipItems)
        return false;

    ImGuiContext& g = *GImGui;
    const ImGuiStyle& style = g.Style;
    const ImGuiID id = window->GetID(label);
    const ImVec2 label_size = ImGui::CalcTextSize(label, NULL, true);

    const float height = ImGui::GetFrameHeight();
    const float width = height * 1.8f;
    const ImVec2 size(width, height);

    const ImRect frame_bb(window->DC.CursorPos, ImVec2(window->DC.CursorPos.x + size.x, window->DC.CursorPos.y + size.y));
    const ImRect total_bb(frame_bb.Min, ImVec2(frame_bb.Max.x + (label_size.x > 0.0f ? style.ItemInnerSpacing.x + label_size.x : 0.0f), frame_bb.Max.y));

    ImGui::ItemSize(total_bb, style.FramePadding.y);
    if (!ImGui::ItemAdd(total_bb, id))
        return false;

    bool hovered, held;
    bool pressed = ImGui::ButtonBehavior(frame_bb, id, &hovered, &held);
    if (pressed)
        *v = !(*v);

    // Draw frame
    const ImU32 frame_col = ImGui::GetColorU32(held ? ImGuiCol_ButtonActive : hovered ? ImGuiCol_ButtonHovered : ImGuiCol_Button);
    ImGui::RenderNavHighlight(frame_bb, id);
    window->DrawList->AddRectFilled(frame_bb.Min, frame_bb.Max, frame_col, height * 0.5f);

    // Draw indicator
    ImVec2 indicator_pos(frame_bb.Min.x + style.FramePadding.x, frame_bb.Min.y + style.FramePadding.y);
    const float indicator_radius = height * 0.5f - style.FramePadding.y * 2.0f;
    const float indicator_offset = *v ? (width - indicator_radius * 2.0f - style.FramePadding.x * 2.0f) : 0.0f;
    
    // Draw background track
    window->DrawList->AddRectFilled(frame_bb.Min, frame_bb.Max, 
        ImGui::GetColorU32(*v ? ImVec4(0.00f, 0.60f, 1.00f, 0.5f) : ImVec4(0.20f, 0.20f, 0.20f, 1.0f)), 
        height * 0.5f);
    
    // Draw indicator circle
    window->DrawList->AddCircleFilled(
        ImVec2(frame_bb.Min.x + indicator_radius + indicator_offset, frame_bb.Min.y + indicator_radius + style.FramePadding.y),
        indicator_radius * 0.8f,
        ImGui::GetColorU32(*v ? ImVec4(0.00f, 0.80f, 1.00f, 1.0f) : ImVec4(0.60f, 0.60f, 0.60f, 1.0f)),
        12);

    // Draw label
    if (label_size.x > 0.0f)
        ImGui::RenderText(ImVec2(frame_bb.Max.x + style.ItemInnerSpacing.x, frame_bb.Min.y + style.FramePadding.y), label);

    return pressed;
}

// Custom slider with segments
bool SegmentSliderFloat(const char* label, float* v, float v_min, float v_max, int segments = 5) {
    ImGuiWindow* window = ImGui::GetCurrentWindow();
    if (window->SkipItems)
        return false;

    ImGuiContext& g = *GImGui;
    const ImGuiStyle& style = g.Style;
    const ImGuiID id = window->GetID(label);
    const float w = ImGui::CalcItemWidth();

    const ImVec2 label_size = ImGui::CalcTextSize(label, NULL, true);
    const ImRect frame_bb(window->DC.CursorPos, ImVec2(window->DC.CursorPos.x + w, window->DC.CursorPos.y + label_size.y + style.FramePadding.y * 2.0f));
    
    const ImRect total_bb(frame_bb.Min, ImVec2(frame_bb.Max.x, frame_bb.Max.y + (label_size.x > 0.0f ? style.ItemInnerSpacing.y + label_size.y : 0.0f)));
    
    ImGui::ItemSize(total_bb, style.FramePadding.y);
    if (!ImGui::ItemAdd(total_bb, id))
        return false;

    // Draw label
    if (label_size.x > 0.0f)
        ImGui::RenderText(ImVec2(frame_bb.Min.x, frame_bb.Max.y - label_size.y), label);

    // Draw segments
    const float segment_width = (w - (segments - 1) * style.ItemSpacing.x) / segments;
    const float segment_height = 8.0f;
    const float segment_y = frame_bb.Min.y + (frame_bb.GetHeight() - segment_height) * 0.5f;
    
    const float t = (*v - v_min) / (v_max - v_min);
    const int active_segments = (int)(t * segments + 0.5f);
    
    for (int i = 0; i < segments; i++) {
        const float segment_x = frame_bb.Min.x + i * (segment_width + style.ItemSpacing.x);
        const ImRect segment_bb(ImVec2(segment_x, segment_y), ImVec2(segment_x + segment_width, segment_y + segment_height));
        
        const ImU32 segment_col = ImGui::GetColorU32(i < active_segments ? 
            ImVec4(0.00f, 0.60f, 1.00f, 1.0f) : 
            ImVec4(0.20f, 0.20f, 0.20f, 1.0f));
        
        window->DrawList->AddRectFilled(segment_bb.Min, segment_bb.Max, segment_col, 2.0f);
    }

    // Handle input
    bool value_changed = false;
    if (ImGui::ItemHoverable(frame_bb, id)) {
        if (g.IO.MouseClicked[0]) {
            const float clicked_t = (g.IO.MousePos.x - frame_bb.Min.x) / w;
            *v = v_min + clicked_t * (v_max - v_min);
            *v = IM_CLAMP(*v, v_min, v_max);
            value_changed = true;
        }
    }

    return value_changed;
}

